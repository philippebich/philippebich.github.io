source "https://rubygems.org"

# Local preview uses plain Jekyll 4 (faster, supports --livereload).
# GitHub Pages will build the site server-side regardless of this Gemfile.
gem "jekyll", "~> 4.3"
gem "jekyll-sass-converter", "~> 2.2"
gem "sassc", "~> 2.4"
gem "webrick", "~> 1.8"

group :jekyll_plugins do
  gem "jekyll-feed"
  gem "jekyll-sitemap"
  gem "jekyll-paginate"
  gem "jekyll-gist"
  gem "jekyll-redirect-from"
  gem "jemoji"
end
